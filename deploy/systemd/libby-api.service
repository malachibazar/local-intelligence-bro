[Unit]
Description=Libby voice API
Wants=network-online.target
After=network-online.target libby-ollama.service
Requires=libby-ollama.service

[Service]
Type=simple
Environment=PYTHONPATH=/home/deck/local-intelligence-bro
ExecStart=/usr/bin/distrobox enter libby -- /home/deck/local-intelligence-bro/.venv/bin/uvicorn --app-dir /home/deck/local-intelligence-bro api:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
